{
  "name": "localpages",
  "version": "0.1.0",
  "description": "Local-only Markdown preview & static export. GitHub aesthetics, zero external API.",
  "license": "MIT",
  "author": "Martin Zlamal",
  "homepage": "https://github.com/mrtnzlml/localpages#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrtnzlml/localpages.git"
  },
  "bugs": {
